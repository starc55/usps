{
  "manifest_version": 3,
  "name": "Load Watcher",
  "version": "2.0.0",
  "permissions": ["storage", "tabs", "alarms"],
  "host_permissions": [
    "https://usps-board.sean.yukla.org/*",
    "https://api.telegram.org/*",
    "https://usps-jgp7.onrender.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://usps-board.sean.yukla.org/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Load Watcher",
    "default_popup": "popup.html"
  }
}